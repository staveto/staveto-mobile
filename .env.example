# Skopíruj na .env a doplň hodnoty.
# Nikdy necommituj .env – je v .gitignore.
#
# PRODUCTION (EAS Build): .env sa neposiela na EAS. Nastav premenné cez EAS Dashboard
# alebo `eas secret:create`. Pozri docs/EAS_ENVIRONMENT_VARIABLES.md.

# Backend API (pôvodný Cloudflare Worker – voliteľné ak používaš len Firebase)
EXPO_PUBLIC_API_URL=https://staveto-app-api.TVOJ_SUBDOMAIN.workers.dev

# Firebase (staveto-mvp) – z Firebase Console → Project settings → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=TVOJ_PROJECT.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=staveto-mvp-5f251
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=staveto-mvp-5f251.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Google Maps Directions API – pre výpočet km pri cestovných výdavkoch (Cestovné A→B)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# RevenueCat – platby (Paywall, predplatné)
# Získaš v RevenueCat dashboard → Project → API Keys
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# AI project creation (voliteľné) – URL z výstupu firebase deploy --only functions:generateProjectStructure
# Ak UNAUTHENTICATED, skopíruj URL z deploy výstupu a vlož sem
# EXPO_PUBLIC_AI_GENERATE_PROJECT_URL=https://...
# EXPO_PUBLIC_AI_CREATE_PROJECT_URL=https://...
# EXPO_PUBLIC_AI_REFINE_PROJECT_NODE_URL=https://... (voliteľné — refine jednej fázy/úlohy)

# ──────────────────────────────────────────────────────────────────────────────
# Staveto Business (B2B) – feature flags
# Default OFF. Nastav na 1 / true len keď chceš zapnúť Business surface
# (drawer entry, BusinessGate, business screens). Nezasahuje do B2C flow.
EXPO_PUBLIC_BUSINESS_ENABLED=

# Whitelist administrátorov pre admin obrazovky (comma-separated, lowercase).
# Príklad: EXPO_PUBLIC_ADMIN_EMAILS=admin@example.com,owner@example.com
# Toto je len defense-in-depth — autoritatívna kontrola je vždy server-side custom claim.
EXPO_PUBLIC_ADMIN_EMAILS=