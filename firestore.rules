rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function hasPhone() { return request.auth.token.phone_number != null; }

    function projectOwner(projectId) {
      return signedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId))
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == uid();
    }

    function isOwner(projectId) {
      return projectOwner(projectId);
    }

    function hasProjectRef(projectId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(uid())/projectRefs/$(projectId));
    }

    function isMember(projectId) {
      return signedIn()
        && (
          hasProjectRef(projectId)
          || (
            exists(/databases/$(database)/documents/projects/$(projectId)/members/$(uid()))
            && (
              !("status" in get(/databases/$(database)/documents/projects/$(projectId)/members/$(uid())).data)
              || get(/databases/$(database)/documents/projects/$(projectId)/members/$(uid())).data.status == "active"
            )
          )
        );
    }

    function memberTaskUpdateAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "status",
        "completedAt",
        "doneAt",
        "updatedAt",
        "notes",
        "progressPercent",
        "startedAt",
        "lastPhotoAt"
      ]);
    }

    function hasAccessDoc(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/membersByUid/$(uid()));
    }
    function access(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/membersByUid/$(uid())).data;
    }
    function canReadTasks(projectId) {
      return isOwner(projectId) || (hasAccessDoc(projectId) && access(projectId).sharedItems.tasks == true) || (isMember(projectId) && !hasAccessDoc(projectId));
    }
    function canReadPhases(projectId) {
      return isOwner(projectId) || (hasAccessDoc(projectId) && access(projectId).sharedItems.phases == true) || (isMember(projectId) && !hasAccessDoc(projectId));
    }
    function canReadExpenses(projectId) {
      return isOwner(projectId) || (hasAccessDoc(projectId) && access(projectId).sharedItems.expenses == true) || (isMember(projectId) && !hasAccessDoc(projectId));
    }
    function canReadDiary(projectId) {
      return isOwner(projectId) || (hasAccessDoc(projectId) && access(projectId).sharedItems.diary == true) || (isMember(projectId) && !hasAccessDoc(projectId));
    }
    function canReadDocuments(projectId) {
      return isOwner(projectId) || (hasAccessDoc(projectId) && access(projectId).sharedItems.documents == true) || (isMember(projectId) && !hasAccessDoc(projectId));
    }
    function canWriteAsEditor(projectId) {
      return isOwner(projectId)
        || (hasAccessDoc(projectId) && (access(projectId).permissionLevel == 'editor' || access(projectId).permissionLevel == 'admin'))
        || (isMember(projectId) && !hasAccessDoc(projectId)
            && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(uid()))
            && (get(/databases/$(database)/documents/projects/$(projectId)/members/$(uid())).data.permissionLevel == 'editor'
                || get(/databases/$(database)/documents/projects/$(projectId)/members/$(uid())).data.permissionLevel == 'admin'));
    }

    // Users (každý len svoj)
    match /users/{userId} {
      // Users can read their own document
      allow read: if signedIn() && uid() == userId;
      
      // Users can create their own document (registration)
      allow create: if signedIn() && uid() == userId
        && (
          !("phoneVerified" in request.resource.data)
          || request.resource.data.phoneVerified == false
          || (request.resource.data.phoneVerified == true && hasPhone())
        );
      
      // Users can update their own document EXCEPT subscription/billing fields
      // subscription, subscriptionStatus, trialStartAt, trialEndAt, planId, entitlement, currentPeriodStartAt, currentPeriodEndAt: server-only
      allow update: if signedIn() && uid() == userId
        && (
          !("phoneVerified" in request.resource.data)
          || request.resource.data.phoneVerified == resource.data.phoneVerified
          || (request.resource.data.phoneVerified == true && hasPhone())
        )
        && (
          (!('subscription' in request.resource.data) || !('subscription' in resource.data) || request.resource.data.subscription == resource.data.subscription)
          ||
          (!('subscription' in resource.data) && request.resource.data.subscription.tier == "FREE" && request.resource.data.subscription.status == "active")
        )
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'subscriptionStatus', 'trialStartAt', 'trialEndAt', 'planId', 'entitlement', 'currentPeriodStartAt', 'currentPeriodEndAt'
        ]);

      // projectRefs: read-only for client (CF writes via admin SDK)
      match /projectRefs/{projectId} {
        allow read: if signedIn() && uid() == userId;
        allow write: if false;
      }

      // limits, usage: read-only for client (CF writes via admin SDK)
      match /limits/{docId} {
        allow read: if signedIn() && uid() == userId;
        allow write: if false;
      }
      match /usage/{docId} {
        allow read: if signedIn() && uid() == userId;
        allow write: if false;
      }

      // all other user subcollections: self-only read/write (projectRefs, limits, usage excluded)
      match /{subcol}/{docId} {
        allow read, write: if signedIn() && uid() == userId && subcol != 'projectRefs' && subcol != 'limits' && subcol != 'usage';
      }
      match /{subcol}/{docId}/{rest=**} {
        allow read, write: if signedIn() && uid() == userId && subcol != 'projectRefs' && subcol != 'limits' && subcol != 'usage';
      }
    }

    // Config (limits): read-only for signed-in users, write by CF only
    match /config/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }
    
    // Billing events (read-only for users, write-only for server)
    match /billingEvents/{eventId} {
      allow read: if signedIn() && resource.data.firebaseUID == uid();
      allow write: if false; // Only Cloud Functions can write
    }

    // Catalog templates (read-only)
    match /catalogTemplates/{templateId} {
      allow read: if signedIn();
      allow write: if false;

      match /{doc=**} {
        allow read: if signedIn();
        allow write: if false;
      }
    }

    // Projects
    match /projects/{projectId} {

      // create projektu: ownerId musí byť aktuálny user
      allow create: if signedIn()
        && request.resource.data.ownerId == uid();

      // read/delete: len owner (fallback allow read for legacy docs without ownerId)
      allow read: if signedIn()
        && (resource.data.ownerId == uid() || isMember(projectId) || !("ownerId" in resource.data));
      allow delete: if signedIn()
        && resource.data.ownerId == uid();

      // update: len owner + ownerId sa nesmie meniť
      allow update: if signedIn()
        && resource.data.ownerId == uid()
        && request.resource.data.ownerId == resource.data.ownerId;

      // members subcollection
      match /members/{memberUid} {
        allow read: if isOwner(projectId) || isMember(projectId);
        allow create, update, delete: if isOwner(projectId);
      }

      // tasks: enforce sharedItems.tasks
      match /tasks/{taskId} {
        allow read: if canReadTasks(projectId);
        allow create, delete: if canWriteAsEditor(projectId);
        allow update: if canWriteAsEditor(projectId)
          || (canReadTasks(projectId) && memberTaskUpdateAllowed());
      }

      // phases: enforce sharedItems.phases
      match /phases/{phaseId} {
        allow read: if canReadPhases(projectId);
        allow write: if canWriteAsEditor(projectId);
      }

      // expenses: enforce sharedItems.expenses
      match /expenses/{expenseId} {
        allow read: if canReadExpenses(projectId);
        allow write: if canWriteAsEditor(projectId);
      }

      // constructionDiary: enforce sharedItems.diary
      match /constructionDiary/{entryId} {
        allow read: if canReadDiary(projectId);
        allow write: if canWriteAsEditor(projectId);
      }

      // documents: enforce sharedItems.documents
      match /documents/{docId} {
        allow read: if canReadDocuments(projectId);
        allow write: if canWriteAsEditor(projectId);
      }

      // attachments: used for tasks, expenses, and documents - allow read if user can read any of these
      match /attachments/{attachmentId} {
        allow read: if canReadTasks(projectId) || canReadExpenses(projectId) || canReadDocuments(projectId);
        allow write: if canWriteAsEditor(projectId);
      }

      // problems: defects/issues per project - read: owner or member; create: owner or editor; update: owner or creator or assignee; delete: owner only
      match /problems/{problemId} {
        allow read: if isOwner(projectId) || isMember(projectId);
        allow create: if canWriteAsEditor(projectId);
        allow update: if isOwner(projectId)
          || resource.data.createdByUid == uid()
          || resource.data.assigneeUid == uid();
        allow delete: if isOwner(projectId);
      }

      // membersByUid: read for self (rules check), write by CF only
      match /membersByUid/{memberUid} {
        allow read: if signedIn() && uid() == memberUid;
        allow write: if false;
      }

      // project activity events ticker
      match /events/{eventId} {
        allow read, write: if isOwner(projectId) || isMember(projectId);
      }

      // other subcollections (stats, phaseStats, equipment, serviceRules...)
      match /{subcol}/{docId} {
        allow read: if signedIn()
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && (
            get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == uid()
            || isMember(projectId)
            || !("ownerId" in get(/databases/$(database)/documents/projects/$(projectId)).data)
          );
        allow write: if signedIn()
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == uid();
      }

      match /{subcol}/{docId}/{subsub=**} {
        allow read: if signedIn()
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && (
            get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == uid()
            || isMember(projectId)
            || !("ownerId" in get(/databases/$(database)/documents/projects/$(projectId)).data)
          );
        allow write: if signedIn()
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == uid();
      }

    }

    // Time entries (time tracking / attendance)
    match /timeEntries/{entryId} {
      allow create: if signedIn()
        && request.resource.data.userId == uid()
        && canWriteAsEditor(request.resource.data.projectId);
      allow read: if signedIn()
        && (resource.data.userId == uid() || canWriteAsEditor(resource.data.projectId));
      allow update, delete: if signedIn() && resource.data.userId == uid();
    }

    // Notifications (inbox)
    match /notifications/{notificationId} {
      allow read: if signedIn() && request.auth.uid == resource.data.userId;
      allow create: if signedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if signedIn()
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readAt"]);
      allow delete: if false;
    }
  }
}
