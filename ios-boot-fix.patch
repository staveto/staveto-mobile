+function logBootDiagnostics(): void {
+  const build = Constants.expoConfig?.version ?? "?";
+  const platform = Platform.OS;
+  const envChecks = {
+    FIREBASE_API_KEY: !!process.env.EXPO_PUBLIC_FIREBASE_API_KEY,
+    REVENUECAT_IOS: !!process.env.EXPO_PUBLIC_REVENUECAT_IOS_API_KEY?.trim(),
+    GOOGLE_WEB_CLIENT_ID: !!process.env.EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID?.trim(),
+  };
+  if (__DEV__) {
+    console.log("[boot] platform:", platform, "build:", build, "env:", envChecks);
+  }
+}
+
+function setupUnhandledRejectionHandler(): void {
+  const handler = (e: PromiseRejectionEvent) => {
+    console.error("[boot] Unhandled rejection:", e?.reason ?? e);
+  };
+  if (typeof global !== "undefined" && "addEventListener" in global) {
+    (global as any).addEventListener?.("unhandledrejection", handler);
+  }
+}
 
