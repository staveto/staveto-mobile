+function BootLoader({ children }: { children: React.ReactNode }) {
+  const [state, setState] = useState<BootState>("booting");
+  const [error, setError] = useState<string | null>(null);
+  const [errorStep, setErrorStep] = useState<string | null>(null);
+  const hideSplashRef = useRef(false);
+
+  const hideSplash = useCallback(async () => {
+    if (hideSplashRef.current) return;
+    hideSplashRef.current = true;
+    try {
+      await SplashScreen.hideAsync();
+    } catch (e) {
+      if (__DEV__) console.warn("[boot] SplashScreen.hideAsync failed:", e);
+    }
+  }, []);
+
+  useEffect(() => {
+    let cancelled = false;
+    (async () => {
+      try {
+        await SplashScreen.preventAutoHideAsync?.();
+      } catch {
+        // ignore
+      }
+      const safeHide = async () => {
+        try {
+          await SplashScreen.hideAsync?.();
+        } catch {
+          // ignore
+        }
+      };
+      try {
+        logBootDiagnostics();
+        setupUnhandledRejectionHandler();
+        if (process.env.EXPO_PUBLIC_SIMULATE_BOOT_FAILURE === "1") {
+          throw new Error("Simulated boot failure (EXPO_PUBLIC_SIMULATE_BOOT_FAILURE=1)");
+        }
+        if (cancelled) return;
+        setState("ready");
+      } catch (e) {
+        if (cancelled) return;
+        const err = e instanceof Error ? e : new Error(String(e));
+        setError(err.message);
+        setErrorStep("boot");
+        setState("error");
+        console.error("[boot] Init failed:", err?.message ?? err, "step:", "boot");
+      } finally {
+        await safeHide();
+      }
+    })();
+    const fallback = setTimeout(() => hideSplash(), 5000);
+    return () => {
+      cancelled = true;
+      clearTimeout(fallback);
+    };
+  }, [hideSplash]);
+
+  if (state === "booting") {
+    return (
+      <View style={styles.loading}>
+        <ActivityIndicator size="large" color={colors.primary} />
+      </View>
+    );
+  }
+
+  if (state === "error") {
+    return (
+      <View style={[styles.loading, { padding: 24 }]}>
+        <Text style={styles.errorTitle}>Startup Error</Text>
+        {errorStep && (
+          <Text style={[styles.errorMessage, { fontSize: 11, color: "rgba(255,255,255,0.6)", marginBottom: 8 }]}>
+            Step: {errorStep}
+          </Text>
+        )}
+        <Text style={styles.errorMessage} selectable>
+          {error ?? "Unknown error"}
+        </Text>
+        <TouchableOpacity
+          style={styles.retryButton}
+          onPress={() => {
+            setState("booting");
+            setError(null);
+            setErrorStep(null);
+            hideSplashRef.current = false;
+          }}
+        >
+          <Text style={styles.retryButtonText}>Retry</Text>
+        </TouchableOpacity>
+      </View>
+    );
+  }
+
+  return <>{children}</>;
+}
