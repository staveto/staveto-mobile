{
  "name": "mobile",
  "version": "1.30.0",
  "main": "index.ts",
  "expo": {
    "install": {
      "exclude": [
        "react-native-reanimated"
      ]
    }
  },
  "scripts": {
    "ensure-logo": "node scripts/ensure-logo.js",
    "postinstall": "node scripts/ensure-logo.js",
    "fix-adaptive-icon": "node scripts/fix-adaptive-icon.js",
    "start": "npm run ensure-logo && expo start",
    "android": "npm run ensure-logo && expo start --android",
    "dev:android": "node scripts/run-android.js",
    "reinstall:android": "node scripts/reinstall-android.js",
    "install:android:win": "cmd /c scripts\\build-android-windows.cmd",
    "run:android": "node scripts/run-android.js",
    "run:android:emulator": "node scripts/run-android.js",
    "start:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/start-emulator.ps1",
    "restart:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-expo-session.ps1",
    "dev:android:external": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-external.ps1",
    "ios": "expo run:ios",
    "run:ios": "expo start --tunnel --dev-client",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production --latest",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "clean:android": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-android.ps1",
    "prebuild:android": "npx expo prebuild --platform android --clean",
    "android:build": "set GRADLE_USER_HOME=C:\\g&& set TMP=C:\\g&& set TEMP=C:\\g&& npx expo run:android",
    "test:ios-diagnostic": "node scripts/test-ios-diagnostic.js",
    "i18n:audit": "node scripts/i18n-audit.js",
    "i18n:add-missing": "node scripts/i18n-add-missing.js",
    "repo-status": "powershell -ExecutionPolicy Bypass -File ./scripts/repo-status.ps1",
    "android:debug-sha": "powershell -ExecutionPolicy Bypass -File ./scripts/android-debug-sha.ps1",
    "test:ai-flow": "node --test scripts/ai-flow-payload-selfcheck.mjs"
  },
  "dependencies": {
    "@google-cloud/vision": "^5.3.4",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/analytics": "^23.8.6",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/auth": "^23.8.6",
    "@react-native-firebase/firestore": "^23.8.6",
    "@react-native-firebase/functions": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-native-firebase/storage": "^23.8.6",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/drawer": "^7.8.1",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "babel-preset-expo": "~54.0.10",
    "date-fns": "^4.1.0",
    "expo": "~54.0.32",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "^55.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-localization": "~17.0.3",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-quick-actions": "^6.0.1",
    "expo-sharing": "~14.0.8",
    "expo-speech-recognition": "^3.1.0",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "libphonenumber-js": "^1.12.36",
    "pako": "^2.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-purchases": "^8.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.19.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/pako": "^2.0.4",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "firebase-admin": "^13.7.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "xlsx": "^0.18.5"
  },
  "private": true
}
