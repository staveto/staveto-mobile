rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function signedIn() {
      return request.auth != null;
    }
    
    function uid() {
      return request.auth.uid;
    }
    
    // Project owner check - same as Firestore rules
    function projectOwner(projectId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/projects/$(projectId))
        && firestore.get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == uid();
    }
    
    // Project member: membersByUid exists OR legacy members/{uid} with status active
    // Matches Firestore isMember semantics
    function isProjectMember(projectId) {
      return signedIn()
        && (
          firestore.exists(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid()))
          || (
            firestore.exists(/databases/(default)/documents/projects/$(projectId)/members/$(uid()))
            && (
              !("status" in firestore.get(/databases/(default)/documents/projects/$(projectId)/members/$(uid())).data)
              || firestore.get(/databases/(default)/documents/projects/$(projectId)/members/$(uid())).data.status == "active"
            )
          )
        );
    }
    
    // Read attachments: owner OR member with tasks/expenses/documents permission (matches Firestore)
    // Legacy members without membersByUid get full read
    function canReadAttachments(projectId) {
      return projectOwner(projectId)
        || (
          isProjectMember(projectId)
          && (
            !firestore.exists(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid()))
            || firestore.get(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid())).data.sharedItems.tasks == true
            || firestore.get(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid())).data.sharedItems.expenses == true
            || firestore.get(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid())).data.sharedItems.documents == true
          )
        );
    }
    
    // Write attachments: owner OR member with permissionLevel == 'editor' or 'admin' (matches Firestore canWriteAsEditor)
    function canWriteAttachments(projectId) {
      return projectOwner(projectId)
        || (
          firestore.exists(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid()))
          && (firestore.get(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid())).data.permissionLevel == 'editor' || firestore.get(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid())).data.permissionLevel == 'admin')
        );
    }
    
    // Unified attachments: projects/{projectId}/attachments/{attachmentId}/{filename}
    // Read: owner or member with tasks/expenses/documents; Write: owner or editor; max 50MB
    match /projects/{projectId}/attachments/{attachmentId}/{filename} {
      allow read: if canReadAttachments(projectId);
      allow write: if canWriteAttachments(projectId)
        && request.resource.size < 50 * 1024 * 1024;
    }
    
    // DEPRECATED: Task attachments nested path (backward compatibility)
    match /projects/{projectId}/tasks/{taskId}/attachments/{attachmentId}/{filename} {
      allow read: if canReadAttachments(projectId);
      allow write: if canWriteAttachments(projectId)
        && request.resource.size < 50 * 1024 * 1024;
    }
    
    // Problem photos: projects/{projectId}/problems/{problemId}/{filename}
    // Read: owner or member; Write: owner or editor; max 15MB per photo
    match /projects/{projectId}/problems/{problemId}/{filename} {
      allow read: if projectOwner(projectId) || isProjectMember(projectId);
      allow write: if canWriteAttachments(projectId)
        && request.resource.size < 15 * 1024 * 1024;
    }
    
    // Equipment photos (MAINTENANCE): projects/{projectId}/equipment/{equipmentId}/photo_*.jpg|png
    match /projects/{projectId}/equipment/{equipmentId}/{filename} {
      allow read: if projectOwner(projectId);
      
      allow write: if projectOwner(projectId)
        && request.resource.size < 10 * 1024 * 1024; // Max 10MB per photo
    }
    
    // Project cover photo: projects/{projectId}/cover/{filename}
    match /projects/{projectId}/cover/{filename} {
      allow read: if signedIn()
        && (projectOwner(projectId)
          || firestore.exists(/databases/(default)/documents/projects/$(projectId)/membersByUid/$(uid())));
      allow write: if projectOwner(projectId)
        && request.resource.size < 10 * 1024 * 1024; // Max 10MB
    }
    
    // User-owned equipment photos (tab Equipment, not project subcollection)
    match /users/{userId}/equipment/{equipmentId}/{fileName} {
      allow read: if signedIn() && uid() == userId;
      allow write: if signedIn() && uid() == userId
        && request.resource.size < 10 * 1024 * 1024;
    }

    // User profile photos
    match /users/{userId}/profile/{fileName} {
      allow read: if signedIn() && uid() == userId;
      allow write: if signedIn() && uid() == userId
        && request.resource.size < 10 * 1024 * 1024; // Max 10MB
    }

    // AI project draft documents (uploaded before project exists, for AI context)
    match /users/{userId}/aiProjectDrafts/{draftId}/documents/{fileName} {
      allow read: if signedIn() && uid() == userId;
      allow write: if signedIn() && uid() == userId
        && request.resource.size < 20 * 1024 * 1024; // Max 20MB per document
    }

    // Deny all other paths (must come after specific matches)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
